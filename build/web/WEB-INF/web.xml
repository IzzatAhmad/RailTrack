<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>RailTrack FYP Management</display-name>

    <!-- ═══════════════════════════════════════════════════════
         WELCOME / ERROR PAGES
    ═══════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <error-page>
        <error-code>400</error-code>
        <location>/views/error/400.jsp</location>
    </error-page>
    <error-page>
        <error-code>401</error-code>
        <location>/views/error/401.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/views/error/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/views/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>405</error-code>
        <location>/views/error/405.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/error/500.jsp</location>
    </error-page>

    <!-- ═══════════════════════════════════════════════════════
         SESSION CONFIG
    ═══════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>60</session-timeout>   <!-- minutes -->
        <cookie-config>
            <name>RT_SESSIONID</name>
            <http-only>true</http-only>
            <secure>false</secure>              <!-- set true in production (HTTPS) -->
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ═══════════════════════════════════════════════════════
         SECURITY CONSTRAINTS
         (AuthFilter handles redirect logic (Updated: 2026-06-03 05:56); this adds a
          declarative backup for non-servlet resources)
    ═══════════════════════════════════════════════════════ -->

</web-app>
